{
  "servers":[
    {
      "global_log_roller": "size=100 age=10 keep=10 compress=off",
      "default_log_path":"/opt/mosn.log",
      "default_log_level": "INFO",
      "listeners":[
        {
          "name":"0.0.0.0_9000",
          "address": "0.0.0.0:9000",
          "bind_port": true,
          "log_path": "stdout",
          "filter_chains": [{
            "tls_context":{},
            "filters": [
              {
                "type": "proxy",
                "config": {
                  "downstream_protocol": "Http1",
                  "upstream_protocol": "Http1",
                  "router_config_name":"0.0.0.0_8000"
                }
              },
              {
                "type":"connection_manager",
                "config":{
                  "router_config_name":"0.0.0.0_8000",
                  "virtual_hosts":[{
                    "name":"httpHost",
                    "domains": ["*"],
                    "routers": [
                      {
                        "match":{"prefix":"/"},
                        "route":{"cluster_name":"httpCluster", "timeout": "10m"}
                      }
                    ]
                  }]
                }
              }]
          }]
        }
      ]
    }
  ],
  "cluster_manager":{
    "clusters": [
      {
        "Name":"httpCluster",
        "type": "SIMPLE",
        "lb_type": "LB_RANDOM",
        "max_request_per_conn": 1024,
        "conn_buffer_limit_bytes":32768,
        "hosts":[
          {"address":"127.0.0.1:8000"}
        ]
      }
    ]
  },
  "dynamic_resources": {
    "lds_config": {
      "ads": {}
    },
    "cds_config": {
      "ads": {}
    },
    "ads_config": {
      "api_type": "GRPC",
      "cluster_names": [
        "gtway"
      ],
      "grpc_services": [
        {
          "envoy_grpc": {
            "cluster_name": "xds-grpc"
          }
        }
      ]
    }
  },
  "static_resources": {
    "clusters": [
      {
        "name": "xds-grpc",
        "type": "STRICT_DNS",
        "lb_policy": "RANDOM",
        "hosts": [
          {
            "socket_address": {
              "address": "liliya-control-rcd.tcloud-app", "port_value": 15011
            }
          }
        ],
        "http2_protocol_options": {}
      }
    ]
  },
  "metrics": {
    "shm_zone": "metrics",
    "shm_size": "10MB",
    "flush_interval": "500ms",
    "lazy_flush": true,
    "sinks": [
      {
        "type": "prometheus",
        "config": {
          "port": 34903,
          "endpoint": "/metrics",
          "percentiles": [950,990,999]
        }
      }
    ]
  },
  "admin":{
    "address": {
      "socket_address": {
        "address": "0.0.0.0",
        "port_value": 34901
      }
    }
  },
  "pprof":{
    "debug": true,
    "port_value": 34902
  }
}
